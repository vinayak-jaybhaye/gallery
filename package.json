{
  "name": "gallery",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:api": "dotenv -e .env -- pnpm --filter gallery-api dev",
    "dev:web": "pnpm --filter gallery-web dev",
    "dev:worker": "dotenv -e .env -- pnpm --filter media-worker dev",
    "build": "pnpm -r build",
    "db:generate": "dotenv -e .env -- pnpm --filter @gallery/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @gallery/db db:migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @gallery/db db:push",
    "db:studio": "dotenv -e .env -- pnpm --filter @gallery/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "packageManager": "pnpm@10.29.2",
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}