generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordAuthEnabled Boolean  @default(false)
  passwordHash        String?
  storageUsedBytes    BigInt   @default(0)
  storageQuotaBytes   BigInt   @default(10737418240)
  avatarUrl           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  media       Media[]
  albums      Album[]
  albumShares AlbumShare[]
  mediaShares MediaShare[]
}

model Media {
  id              String      @id @default(uuid())
  ownerId         String
  type            MediaType
  originalKey     String
  masterKey       String?
  thumbnailKey    String?
  mimeType        String
  sizeBytes       BigInt?
  width           Int?
  height          Int?
  durationSeconds Int?
  takenAt         DateTime?
  title           String
  status          MediaStatus
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  uploadSession UploadSession?
  albumMedias   AlbumMedia[]
  mediaShares   MediaShare[]
  publicShares  PublicShare[]
  albums        Album[]

  @@index([ownerId, deletedAt(sort: Desc), id], where: { deletedAt: { not: null } })
  @@index([ownerId, status, createdAt(sort: Desc)])
}

model UploadSession {
  id         String       @id @default(uuid())
  mediaId    String       @unique
  s3UploadId String       @unique
  source     UploadSource @default(file)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Album {
  id           String   @id @default(uuid())
  ownerId      String
  title        String
  coverMediaId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner      User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  coverMedia Media? @relation(fields: [coverMediaId], references: [id], onDelete: SetNull)

  media  AlbumMedia[]
  shares AlbumShare[]

  @@index([ownerId, createdAt(sort: Desc)])
}

model AlbumMedia {
  albumId String
  mediaId String
  addedAt DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([albumId, mediaId])
  @@index([mediaId])
}

model AlbumShare {
  id        String    @id @default(uuid())
  albumId   String
  userId    String
  role      AlbumRole @default(viewer)
  createdAt DateTime  @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumId, userId])
  @@index([userId])
}

model MediaShare {
  id        String   @id @default(uuid())
  mediaId   String
  userId    String
  createdAt DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
  @@index([userId])
}

model PublicShare {
  id        String    @id @default(uuid())
  token     String    @unique
  mediaId   String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

enum MediaType {
  image
  video
}

enum MediaStatus {
  uploading
  processing
  ready
  deleted
}

enum UploadSource {
  file
  streaming
}

enum AlbumRole {
  viewer
  editor
}
